{
  "name": "opencode-memfs",
  "version": "0.0.5",
  "description": "OpenCode memory plugin — git-backed, two-tier hot/cold MemFS with progressive disclosure",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "opencode",
    "plugin",
    "memory",
    "memfs",
    "git",
    "persistent",
    "context"
  ],
  "author": "nguquen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nguquen/opencode-memfs.git"
  },
  "homepage": "https://github.com/nguquen/opencode-memfs#readme",
  "bugs": {
    "url": "https://github.com/nguquen/opencode-memfs/issues"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@opencode-ai/sdk": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
